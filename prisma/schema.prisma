generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectRole {
  ADMIN
  MEMBER
  CLIENT
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum CommentStatus {
  OPEN
  IN_PROGRESS
  IN_REVIEW
  RESOLVED
}

enum CommentVisibility {
  PUBLIC
  INTERNAL
}

enum PageSource {
  WIDGET
  MANUAL
  SITEMAP
  IMPORT
}

enum ActivityType {
  PROJECT_CREATED
  PROJECT_UPDATED
  WIDGET_INSTALLED
  DOMAIN_ADDED
  PAGE_DETECTED
  COMMENT_CREATED
  COMMENT_UPDATED
  COMMENT_ASSIGNED
  COMMENT_STATUS_CHANGED
  COMMENT_REPLIED
  INVITE_SENT
  INVITE_ACCEPTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  workspaceMemberships WorkspaceMember[]
  projectMemberships   ProjectMember[]

  comments         Comment[]              @relation("CommentAuthor")
  assignedComments Comment[]              @relation("CommentAssignee")
  replies          CommentReply[]
  statusChanges    CommentStatusHistory[]
  activities       ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id   String @id @default(cuid())
  name String
  slug String @unique

  members    WorkspaceMember[]
  projects   Project[]
  invites    Invite[]
  activities ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Project {
  id          String @id @default(cuid())
  workspaceId String

  name        String
  slug        String
  description String?

  widgetPublicKey String @unique
  widgetSecretKey String @unique

  status ProjectStatus @default(ACTIVE)

  setupCompletedAt DateTime?
  lastWidgetPingAt DateTime?
  archivedAt       DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  members    ProjectMember[]
  domains    ProjectDomain[]
  pages      Page[]
  comments   Comment[]
  invites    Invite[]
  activities ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([status])
}

model ProjectDomain {
  id        String @id @default(cuid())
  projectId String

  domain         String
  isVerified     Boolean   @default(false)
  lastDetectedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([projectId, domain])
  @@index([domain])
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Page {
  id        String @id @default(cuid())
  projectId String

  url   String
  path  String
  title String?

  source     PageSource @default(WIDGET)
  isArchived Boolean    @default(false)

  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime?

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, url])
  @@index([projectId])
  @@index([path])
  @@index([source])
}

model Comment {
  id        String @id @default(cuid())
  projectId String
  pageId    String
  authorId  String

  assigneeId String?

  number  Int
  message String

  status     CommentStatus     @default(OPEN)
  visibility CommentVisibility @default(PUBLIC)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  page    Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)

  author   User  @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  assignee User? @relation("CommentAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  position      CommentPosition?
  replies       CommentReply[]
  statusHistory CommentStatusHistory[]

  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, number])
  @@index([projectId, status])
  @@index([pageId, status])
  @@index([authorId])
  @@index([assigneeId])
}

model CommentPosition {
  id        String @id @default(cuid())
  commentId String @unique

  x Float
  y Float

  viewportWidth  Int
  viewportHeight Int

  scrollX Int @default(0)
  scrollY Int @default(0)

  domPath     String?
  cssSelector String?

  elementText String?
  elementTag  String?

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model CommentReply {
  id        String @id @default(cuid())
  commentId String
  authorId  String

  message    String
  visibility CommentVisibility @default(PUBLIC)

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([commentId])
  @@index([authorId])
}

model CommentStatusHistory {
  id          String @id @default(cuid())
  commentId   String
  changedById String

  fromStatus CommentStatus?
  toStatus   CommentStatus

  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  changedBy User    @relation(fields: [changedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([commentId])
  @@index([changedById])
}

model Invite {
  id          String  @id @default(cuid())
  workspaceId String
  projectId   String?

  email String

  workspaceRole WorkspaceRole?
  projectRole   ProjectRole?

  token String @unique

  expiresAt  DateTime
  acceptedAt DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([projectId])
  @@index([email])
}

model ActivityLog {
  id          String  @id @default(cuid())
  workspaceId String
  projectId   String?
  actorId     String?

  type    ActivityType
  message String?

  metadata Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor     User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([projectId])
  @@index([actorId])
  @@index([type])
}
